# ============================================================================
# IDPro .gitignore
#
# This repo is CODE ONLY. Checkpoints and bulk data live on HuggingFace:
#   Models:  https://huggingface.co/<org>/idpro-*
#   Data:    https://huggingface.co/datasets/<org>/idpro-*
#
# Anything regenerable from the data-pipeline scripts in
# datasets/training_data/scripts/ is excluded here. The pipeline +
# training code is kept; the byproducts are not.
# ============================================================================

# ── Local environment file (paths to data/runs/Qwen weights) ───────────────
env.sh

# ── Archived legacy scripts (P2T finetune/eval, probe runners) ─────────────
archive/

# ── Run outputs (checkpoints, training_results, probe outputs) ─────────────
runs/

# ── Model checkpoints (multi-TB, HuggingFace) ───────────────────────────────
idpro/checkpoints/
idpro/models/
checkpoints/
models/

# ── Training run artifacts ──────────────────────────────────────────────────
idpro/training_results/
training_results/
logs/
*.log
launch_logs/

# ── Generated training data (regenerable; HuggingFace) ─────────────────────
datasets/training_data/qa_stages/
datasets/training_data/qa_stages_*/

# ── AlphaFold PDBs + accessions (multi-100k files; regenerable) ─────────────
datasets/alphafold/pdbs/
datasets/alphafold/accessions.txt
datasets/alphafold/logs/

# ── Derived embeddings, manifests, indices (regenerable) ────────────────────
idpro/data/probe/embeddings/
idpro/data/probe/embeddings_*/
idpro/data/structure_manifest.jsonl
idpro/data/feature_index.pkl
idpro/data/rag_index*
datasets/probe_data/rag/index*
datasets/probe_data/extracted_embeddings/
datasets/probe_data/probe_splits/
datasets/probe_data/baseline_predictions/
datasets/probe_data/uniprot_metadata_cache.jsonl

# ── Generated reports / analysis output (regenerable) ───────────────────────
/reports/

# ── Experiments not yet implemented ────────────────────────────────────────
idpro/experiments/aim2/

# ── Proposal-only material (out of scope for the code repo) ─────────────────
proposal/
meetings/
writing_style/
docs/

# ── All markdown except the root README ────────────────────────────────────
# (Keeps the repo to code + small JSON/JSONL eval-set descriptors. Documentation
# that needs to ship lives in code docstrings or HuggingFace model cards.)
*.md
!README.md

# Folders that contain only markdown (now empty after the *.md rule)
plans/

# ── Local-only HF release tooling (export + push) ──────────────────────────
# The exporter and uploader live here so HF tokens and packaged checkpoints
# never enter git. The downstream `IDProModel.from_pretrained` loader IS
# committed (it's how others consume the published artifact).
tools/hf/
release/

# ── Local agent / IDE state ─────────────────────────────────────────────────
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/

# ── Environments ────────────────────────────────────────────────────────────
.env
.envrc
.venv/
venv/
env/

# ── HuggingFace / Torch cache ───────────────────────────────────────────────
.cache/
.hf_cache/
hf_cache/

# ── Large binary artifacts (catch-all; nothing in code should be these) ─────
*.ckpt
*.pt
*.pth
*.bin
*.safetensors
*.h5
*.hdf5
*.pkl
*.npy
*.npz
*.parquet
*.arrow
*.feather
*.pdb
*.cif
*.mmcif
*.zip
*.tar
*.tar.gz
*.tgz
*.zst
*.7z

# ── Office / proposal docs (don't belong in a code repo) ────────────────────
*.docx
*.doc
*.pptx
*.ppt
*.xlsx
*.xls
*.pdf

# ── Jupyter scratch ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
