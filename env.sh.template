#!/usr/bin/env bash
# IDPro environment variables. Copy to env.sh and fill in your paths.
# Then `source env.sh` from the repo root before running training or eval.
#
#   cp env.sh.template env.sh
#   $EDITOR env.sh
#   source env.sh
#   python -m idpro.training.train --stage 1
#
# env.sh is gitignored — it stays local to your machine.

# Read-only data inputs (qa_stages/, feature_index.pkl, etc.). Small probe
# data is shipped in-repo under datasets/probe_data/; the large training
# corpora and AlphaFold PDBs default to datasets/training_data/ and
# datasets/alphafold/ on disk (gitignored). Override here if you keep
# them elsewhere.
export IDPRO_DATA_ROOT="/path/to/your/data/root"

# Writable outputs (checkpoints, training_results, probe outputs)
export IDPRO_RUNS_ROOT="/path/to/your/runs/root"

# Qwen 3.5 27B weights snapshot directory
export IDPRO_QWEN_PATH="/path/to/qwen3.5-27b/snapshot"

# Optional — defaults to the repo root containing this file
# export IDPRO_REPO_ROOT="/path/to/idpro_struct"

# Optional — only needed for setup_qwen.sh first-time download
# export IDPRO_HF_CACHE="$IDPRO_RUNS_ROOT/hf_cache"

# Optional — only needed for train_60hr.py
# export IDPRO_P2T_DIR="/path/to/Protein2Text"
